{
  "targetVersion": "1.35",
  "scope": "Managed AKS validation on a Kubernetes 1.34 cluster with Kubernetes-modern manifests. Deprecated API fixtures are intentionally excluded because the managed API server rejects removed API versions.",
  "negativeControls": [
    {
      "id": "neg-safe-deployment",
      "description": "Deployment with three replicas, readinessProbe, restricted-compatible security context, and matching PDB.",
      "resource": {
        "apiVersion": "apps/v1",
        "kind": "Deployment",
        "namespace": "aksv-safe",
        "name": "profile-api"
      }
    },
    {
      "id": "neg-safe-webhook",
      "description": "Webhook with failurePolicy=Ignore, existing service, namespaceSelector, and objectSelector.",
      "resource": {
        "apiVersion": "admissionregistration.k8s.io/v1",
        "kind": "ValidatingWebhookConfiguration",
        "name": "r02-safe-webhook"
      }
    },
    {
      "id": "neg-policy-warn-audit-only",
      "description": "Namespace uses Pod Security warn/audit labels without enforce; current checker should not treat it as an enforced policy blocker.",
      "resource": {
        "apiVersion": "v1",
        "kind": "Namespace",
        "name": "aksv-policy-warn-audit"
      }
    },
    {
      "id": "neg-modern-hpa",
      "description": "Modern autoscaling/v2 HPA should not be reported by the deprecated API checker.",
      "resource": {
        "apiVersion": "autoscaling/v2",
        "kind": "HorizontalPodAutoscaler",
        "namespace": "aksv-modern-api",
        "name": "modern-hpa"
      }
    },
    {
      "id": "neg-modern-pdb",
      "description": "Modern policy/v1 PDB should not be reported by the deprecated API checker or PDB checker when it permits one unavailable pod.",
      "resource": {
        "apiVersion": "policy/v1",
        "kind": "PodDisruptionBudget",
        "namespace": "aksv-modern-api",
        "name": "modern-hpa-target"
      }
    }
  ],
  "expectedFindings": [
    {
      "id": "gt-workload-low-replicas",
      "family": "WorkloadAvailability",
      "type": "WORKLOAD_AVAILABILITY_RISK",
      "severity": "High",
      "resource": {
        "apiVersion": "apps/v1",
        "kind": "Deployment",
        "namespace": "aksv-low-replicas",
        "name": "payment-api"
      },
      "messageContains": "fewer than 2 replicas"
    },
    {
      "id": "gt-workload-stateful-single",
      "family": "WorkloadAvailability",
      "type": "WORKLOAD_AVAILABILITY_RISK",
      "severity": "High",
      "resource": {
        "apiVersion": "apps/v1",
        "kind": "StatefulSet",
        "namespace": "aksv-stateful-single",
        "name": "ledger-db"
      },
      "messageContains": "fewer than 2 replicas"
    },
    {
      "id": "gt-readiness-missing-deployment",
      "family": "ReadinessProbes",
      "type": "MISSING_READINESS_PROBE",
      "severity": "Medium",
      "resource": {
        "apiVersion": "apps/v1",
        "kind": "Deployment",
        "namespace": "aksv-readiness",
        "name": "checkout-api"
